# .code-cat.yml — place this file in your repo root to override ccat defaults.
# All fields are optional.

# base_branch: main          # default trunk for new-task and home when unset (remote default via origin/HEAD)
# branch_prefix: "feat/"     # prepended to branch names entered interactively (default: "")
# worktree_root: "../wt"     # default path segment for new-worktree prompts, relative to repo root (default: ..); new-worktree always branches from remote default unless --base
